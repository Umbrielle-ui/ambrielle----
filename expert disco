def ask_question(q) 
    while True:  # loop: keeps asking until answer is valid
        answer = input( q + "(yes/no): ")
        if answer == "yes"
            return 1
        elif answer == "no"
            return 0
        else:
            print("Please dont mess around, just answer yes or no") # repeats if invalid 
            
