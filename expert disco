def ask_question(q):
    while True:
        answer = input(q + " (yes/no): ").lower()
        if answer == "yes":
            return 1
        elif answer == "no":
            return 0
        else:
            print("Please don't mess around, just answer yes or no.")

def score_evaluation(score):
    print("\nResults:")
    if score <= 3:
        print("You might not feel confident when speaking in front yet...")
        print("Try this:")
        print("- Practice in front of a mirror")
        print("- Practice with your friends")
        print("- Prepare more before speaking")
    elif score <= 6:
        print("You're somewhat okay but still need improvement!")
        print("Tips:")
        print("- Work on eye contact")
        print("- Record yourself practicing")
        print("- Observe people talking in front")
    elif score <= 10:
        print("Congrats! You are very confident when speaking in front!")
        print("Tips:")
        print("- Keep practicing your presentation")
        print("- Practice with others")
    else:
        print("Invalid score, try again.")

# ---------- MAIN PROGRAM ----------
score = 0

